    "# Cell 5 \u2014 Metrics Callback\n",
    "class MetricsCallback(BaseCallback):\n",
    "    \"\"\"\n",
    "    Records per-episode success, reward, and steps.\n",
    "    Attaches to SB3 training loop.\n",
    "    \"\"\"\n",
    "    def __init__(self, verbose=0):\n",
    "        super().__init__(verbose)\n",
    "        self.episode_rewards = []\n",
    "        self.episode_lengths = []\n",
    "        self.successes = []\n",
    "        self._current_reward = 0.0\n",
    "        self._current_steps  = 0\n",
    "\n",
    "    def _on_step(self) -> bool:\n",
    "        self._current_reward += self.locals[\"rewards\"][0]\n",
    "        self._current_steps  += 1\n",
    "\n",
    "        done = self.locals[\"dones\"][0]\n",
    "        if done:\n",
    "            info = self.locals[\"infos\"][0]\n",
    "            self.episode_rewards.append(self._current_reward)\n",
    "            self.episode_lengths.append(self._current_steps)\n",
    "            # SB3 Monitor wraps set \"episode\" key on done\n",
    "            success = self._current_reward > 0\n",
    "            self.successes.append(int(success))\n",
    "            self._current_reward = 0.0\n",
    "            self._current_steps  = 0\n",
    "        return True\n",
    "\n",
    "    def success_rate(self):\n",
    "        if not self.successes:\n",
    "            return 0.0\n",
    "        return sum(self.successes) / len(self.successes)"
   ],
