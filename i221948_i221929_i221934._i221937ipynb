    "# Cell 8 \u2014 Baseline PPO (no LLM) for fair comparison\n",
    "print(\"Training baseline PPO (no LLM reward shaping) on 5\u00d75 ...\")\n",
    "\n",
    "env_base = DummyVecEnv([make_env(\"MiniGrid-Empty-5x5-v0\")])\n",
    "baseline_cb = MetricsCallback()\n",
    "\n",
    "baseline_model = PPO(\n",
    "    \"CnnPolicy\", env_base,\n",
    "    policy_kwargs=policy_kwargs,\n",
    "    learning_rate=3e-4,\n",
    "    n_steps=256,\n",
    "    batch_size=64,\n",
    "    n_epochs=4,\n",
    "    gamma=0.99,\n",
    "    ent_coef=0.01,\n",
    "    verbose=0,\n",
    ")\n",
    "baseline_model.learn(total_timesteps=60_000, callback=baseline_cb, reset_num_timesteps=True)\n",
    "env_base.close()\n",
    "\n",
    "print(f\"Baseline PPO success rate: {baseline_cb.success_rate()*100:.1f}%\")\n",
    "print(f\"Baseline avg reward: {np.mean(baseline_cb.episode_rewards):.3f}\")"
