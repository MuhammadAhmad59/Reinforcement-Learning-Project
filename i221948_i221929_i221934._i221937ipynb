    " LLM reward shaper (our key improvement over the paper)"
   ],
   "metadata": {
    "id": "eO4yJGzVJ_6c"
   }
  },
  {
   "cell_type": "code",
   "source": [
    "# Cell 4 \u2014 LLM Reward Shaper\n",
    "class LLMRewardShaper:\n",
    "    \"\"\"\n",
    "    Uses a small LLM to generate an auxiliary reward bonus based on\n",
    "    natural language description of the agent's state.\n",
    "    This augments PPO's environment reward rather than replacing it.\n",
    "\n",
    "    Improvement over original paper:\n",
    "      - LLM guides learning but PPO handles the actual policy\n",
    "      - Much faster: DistilGPT-2 inference is ~50x faster than LLaMA-3B\n",
    "      - Stable: PPO optimization prevents reward hacking\n",
    "    \"\"\"\n",
    "    def __init__(self, model_name=\"distilgpt2\", lambda_llm=0.1):\n",
    "        print(f\"Loading LLM: {model_name} ...\")\n",
    "        self.tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
    "        self.model = AutoModelForCausalLM.from_pretrained(model_name).to(device)\n",
    "        self.model.eval()\n",
    "        self.lambda_llm = lambda_llm  # weight of LLM bonus vs env reward\n",
    "        if self.tokenizer.pad_token is None:\n",
    "            self.tokenizer.pad_token = self.tokenizer.eos_token\n",
    "        print(\"LLM loaded.\")\n",
    "\n",
    "    def state_to_text(self, agent_pos, goal_pos, agent_dir, step):\n",
    "        \"\"\"Convert numeric state to natural language for LLM.\"\"\"\n",
    "        dirs = [\"right\", \"down\", \"left\", \"up\"]\n",
    "        direction = dirs[agent_dir % 4]\n",
    "        dx = goal_pos[0] - agent_pos[0]\n",
    "        dy = goal_pos[1] - agent_pos[1]\n",
    "        h_desc = f\"{'right' if dx > 0 else 'left'} by {abs(dx)}\" if dx != 0 else \"\"\n",
    "        v_desc = f\"{'down' if dy > 0 else 'up'} by {abs(dy)}\" if dy != 0 else \"\"\n",
    "        dist_desc = \", \".join(filter(None, [h_desc, v_desc])) or \"at goal\"\n",
    "        return (\n",
    "            f\"Agent at {agent_pos}, facing {direction}. \"\n",
    "            f\"Goal is {dist_desc}. Step {step}. \"\n",
    "            f\"Should agent move forward?\"\n",
    "        )\n",
    "\n",
    "    @torch.no_grad()\n",
    "    def get_bonus(self, agent_pos, goal_pos, agent_dir, step):\n",
    "        \"\"\"\n",
    "        Returns a small LLM-derived bonus reward in range [0, lambda_llm].\n",
    "        Bonus is higher when the LLM predicts 'yes' (move toward goal).\n",
    "        \"\"\"\n",
    "        prompt = self.state_to_text(agent_pos, goal_pos, agent_dir, step)\n",
    "        inputs = self.tokenizer(\n",
    "            prompt, return_tensors=\"pt\",\n",
    "            truncation=True, max_length=64\n",
    "        ).to(device)\n",
    "\n",
    "        outputs = self.model(**inputs)\n",
    "        logits = outputs.logits[:, -1, :]  # last token logits\n",
    "\n",
    "        # Get probability of \"yes\"-like tokens vs \"no\"-like tokens\n",
    "        yes_ids = self.tokenizer.encode(\" yes Yes forward\", add_special_tokens=False)\n",
    "        no_ids  = self.tokenizer.encode(\" no No backward stop\", add_special_tokens=False)\n",
    "\n",
    "        yes_score = logits[0, yes_ids].mean().item()\n",
    "        no_score  = logits[0, no_ids].mean().item()\n",
    "\n",
    "        # Normalize to [0, 1] and scale by lambda\n",
    "        ratio = torch.sigmoid(torch.tensor(yes_score - no_score)).item()\n",
    "        return self.lambda_llm * ratio"
   ],
