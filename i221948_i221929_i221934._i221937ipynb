    "# Cell 6 \u2014 Environment factory\n",
    "def make_env(env_id, seed=42):\n",
    "    \"\"\"Creates a wrapped MiniGrid env compatible with SB3.\"\"\"\n",
    "    def _init():\n",
    "        env = gym.make(env_id, render_mode=\"rgb_array\")\n",
    "        env = ImgObsWrapper(env)     # dict obs \u2192 image obs\n",
    "        env = Monitor(env)           # episode stats\n",
    "        env.reset(seed=seed)\n",
    "        return env\n",
    "    return _init\n",
    "\n",
    "# Curriculum stages (key improvement: progressive difficulty)\n",
    "CURRICULUM = [\n",
    "    (\"MiniGrid-Empty-5x5-v0\",   60_000,  \"Stage 1: 5\u00d75\"),\n",
    "    (\"MiniGrid-Empty-8x8-v0\",   100_000, \"Stage 2: 8\u00d78\"),\n",
    "    (\"MiniGrid-Empty-16x16-v0\", 200_000, \"Stage 3: 16\u00d716\"),\n",
    "]\n",
    "\n",
    "policy_kwargs = dict(\n",
    "    features_extractor_class=MinigridFeaturesExtractor,\n",
    "    features_extractor_kwargs=dict(features_dim=128),\n",
    ")"
   ],
