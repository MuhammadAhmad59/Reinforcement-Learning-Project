   "cell_type": "code",
   "source": [
    "# Cell 7 \u2014 Main training loop (the big one \u2014 runs ~20-30 min on Colab GPU)\n",
    "import time\n",
    "\n",
    "# Load LLM reward shaper\n",
    "llm_shaper = LLMRewardShaper(model_name=\"distilgpt2\", lambda_llm=0.1)\n",
    "\n",
    "all_callbacks = {}\n",
    "model = None\n",
    "\n",
    "for env_id, timesteps, stage_name in CURRICULUM:\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"  {stage_name}  \u2014  {env_id}\")\n",
    "    print(f\"  Timesteps: {timesteps:,}\")\n",
    "    print(f\"{'='*50}\")\n",
    "\n",
    "    env = DummyVecEnv([make_env(env_id)])\n",
    "    callback = MetricsCallback()\n",
    "\n",
    "    if model is None:\n",
    "        # First stage \u2014 create fresh PPO model\n",
    "        model = PPO(\n",
    "            \"CnnPolicy\",\n",
    "            env,\n",
    "            policy_kwargs=policy_kwargs,\n",
    "            learning_rate=3e-4,\n",
    "            n_steps=256,\n",
    "            batch_size=64,\n",
    "            n_epochs=4,\n",
    "            gamma=0.99,\n",
    "            gae_lambda=0.95,\n",
    "            clip_range=0.2,\n",
    "            ent_coef=0.01,   # entropy bonus for exploration\n",
    "            verbose=0,\n",
    "        )\n",
    "    else:\n",
    "        # Subsequent stages \u2014 transfer weights, swap environment\n",
    "        model.set_env(env)\n",
    "\n",
    "    t0 = time.time()\n",
    "    model.learn(total_timesteps=timesteps, callback=callback, reset_num_timesteps=False)\n",
    "    elapsed = time.time() - t0\n",
    "\n",
    "    sr = callback.success_rate()\n",
    "    avg_r = np.mean(callback.episode_rewards) if callback.episode_rewards else 0\n",
    "    std_r = np.std(callback.episode_rewards) if callback.episode_rewards else 0\n",
    "\n",
    "    print(f\"\\n  Results for {stage_name}:\")\n",
    "    print(f\"  Episodes:     {len(callback.successes)}\")\n",
    "    print(f\"  Success rate: {sr*100:.1f}%\")\n",
    "    print(f\"  Avg reward:   {avg_r:.3f} \u00b1 {std_r:.3f}\")\n",
    "    print(f\"  Training time: {elapsed:.0f}s\")\n",
    "\n",
    "    all_callbacks[stage_name] = callback\n",
    "    env.close()\n",
    "\n",
    "print(\"\\nTraining complete!\")"
